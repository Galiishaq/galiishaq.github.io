---
interface Props {
  title: string;
  description: string;
  tech: string[];
  concepts: string[];
  github?: string;
  live?: string;
}
const { title, description, tech, concepts, github, live } = Astro.props;
---
<article class="card">
  <div class="card-body">
    <h3>{title}</h3>
    <p>{description}</p>

    {concepts.length > 0 && (
      <div class="concepts">
        {concepts.map(c => <span class="concept">{c}</span>)}
      </div>
    )}

    <div class="tech-row">
      {tech.map(t => <span class="tag">{t}</span>)}
    </div>
  </div>

  {(github || live) && (
    <div class="card-links">
      {github && <a href={github} target="_blank" rel="noopener">GitHub →</a>}
      {live && <a href={live} target="_blank" rel="noopener">Live →</a>}
    </div>
  )}
</article>

<style>
  .card {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    transition: border-color 0.15s, box-shadow 0.15s;
    display: flex;
    flex-direction: column;
  }
  .card:hover {
    border-color: #93c5fd;
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.06);
  }
  .card-body {
    padding: 1.5rem;
    flex: 1;
  }
  h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }
  p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .concepts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
  }
  .concept {
    font-size: 0.72rem;
    color: var(--accent);
    background: var(--accent-light);
    border-radius: 4px;
    padding: 0.15em 0.6em;
    font-weight: 500;
  }
  .tech-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .card-links {
    padding: 0.85rem 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 1.25rem;
  }
  .card-links a {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--muted);
  }
  .card-links a:hover {
    color: var(--accent);
    text-decoration: none;
  }
</style>
